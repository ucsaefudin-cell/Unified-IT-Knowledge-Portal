# ============================================================
# Template variabel lingkungan — Unified IT Knowledge Portal
# Salin file ini menjadi .env dan isi nilainya sesuai lingkungan Anda
# JANGAN commit file .env ke Git — hanya .env.example yang boleh di-commit
# ============================================================

# --- Konfigurasi Flask ---
FLASK_ENV=development
SECRET_KEY=ganti-dengan-secret-key-yang-kuat-dan-acak

# --- Database ---
# Development: biarkan kosong → otomatis pakai SQLite lokal (instance/portal_dev.db)
# Production (GCP Cloud SQL PostgreSQL): isi dengan URL koneksi lengkap
# Format: postgresql://USERNAME:PASSWORD@PUBLIC_IP:5432/DATABASE_NAME
DATABASE_URL=

# --- Email (Gmail SMTP) ---
# Gunakan App Password Gmail, bukan password akun utama
# Aktifkan di: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=email-gmail-anda@gmail.com
MAIL_PASSWORD=app-password-gmail-anda

# --- GCP Cloud Storage ---
# Nama bucket untuk menyimpan static assets (CSS, JS, gambar)
GCP_BUCKET_NAME=nama-bucket-gcp-anda

# --- GCP Compute Engine Scheduler ---
# Instance ID dari VM GCP yang akan dijadwalkan start/stop
# Temukan di: GCP Console → Compute Engine → VM Instances
GCP_INSTANCE_ID=nama-instance-gcp-anda
GCP_ZONE=asia-southeast2-a
GCP_PROJECT_ID=project-id-gcp-anda
